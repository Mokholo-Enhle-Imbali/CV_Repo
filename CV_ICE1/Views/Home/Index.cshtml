<style>
    /* Modern CV Styling - Optimized for .cshtml */
    :root {
        --primary: #2c3e50;
        --secondary: #3498db;
        --accent: #e74c3c;
        --light: #f8f9fa;
        --shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        min-height: 100vh;
        padding: 30px 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
    }

    /* Header Section */
    .text-center {
        background: white;
        border-radius: 15px;
        padding: 40px;
        margin: 0 auto 30px auto;
        max-width: 1200px;
        box-shadow: var(--shadow);
        position: relative;
    }

        .text-center h1 {
            color: var(--primary);
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0 0 10px 0;
        }

        .text-center p {
            color: #666;
            font-size: 1.2rem;
            margin: 0 0 20px 0;
        }

    .btn-primary {
        background: var(--secondary);
        border: none;
        padding: 12px 30px;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 50px;
        color: white;
        text-decoration: none;
        display: inline-block;
        transition: 0.3s;
    }

        .btn-primary:hover {
            background: #2980b9;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(52,152,219,0.4);
        }

    /* Cards */
    .card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: var(--shadow);
        background: white;
        height: 100%;
        margin-bottom: 20px;
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

    .card-title {
        color: var(--primary);
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 0 15px 0;
        padding-bottom: 10px;
        border-bottom: 3px solid var(--secondary);
    }

    .card-body {
        padding: 25px;
    }

    /* Profile Image */
    .card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.3s;
    }

    .card:hover img {
        transform: scale(1.05);
    }

    /* Skills List */
    ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        ul li {
            padding: 10px 15px;
            margin-bottom: 8px;
            background: var(--light);
            border-radius: 50px;
            color: #333;
            transition: 0.3s;
        }

            ul li:hover {
                background: var(--secondary);
                color: white;
                transform: translateX(5px);
            }

    /* Experience Section */
    .mt-0 ul li {
        background: white;
        border: 1px solid #ddd;
        border-radius: 10px;
        display: block;
    }

        .mt-0 ul li strong {
            color: var(--primary);
            display: block;
            font-size: 1.1rem;
            margin-bottom: 5px;
        }

        .mt-0 ul li span {
            color: var(--secondary);
            font-size: 0.9rem;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 5px;
        }

    /* Layout */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -10px 20px -10px;
    }

    .col-md-6, .col-md-8 {
        padding: 0 10px;
        box-sizing: border-box;
    }

    .col-md-6 {
        width: 50%;
    }

    .col-md-8 {
        width: 66.666%;
    }

    /* Mobile Responsive */
    @@media (max-width: 768px) {
        body {
            padding: 15px;
        }

        .col-md-6, .col-md-8 {
            width: 100%;
        }

        .text-center h1 {
            font-size: 2rem;
        }

        .text-center {
            padding: 25px;
        }
    }

    /* Utility Classes */
    .mt-0 {
        margin-top: 0 !important;
    }

    .w-100 {
        width: 100%;
    }

    .h-100 {
        height: 100%;
    }
</style>

